<Window x:Class="kennel.KennelNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Kennel"
        Height="170"
        Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Kennel name" FontWeight="SemiBold" Margin="0,0,0,8" />

        <TextBox x:Name="NameTextBox" Grid.Row="1" Height="28" MinWidth="200" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click" />
            <Button Content="OK" Width="80" IsDefault="True" Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>

