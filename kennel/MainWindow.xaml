<Window x:Class="kennel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:kennel"
        mc:Ignorable="d"
        Title="Kennel Organiser"
        Height="320"
        Width="520"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Window heading -->
        <TextBlock
            Grid.Row="0"
            Text="Kennel Organiser"
            FontSize="22"
            FontWeight="SemiBold"
            Margin="0,0,0,12" />

        <!-- Placeholder area for the organisation blocks -->
        <Border
            Grid.Row="1"
            CornerRadius="10"
            BorderThickness="1"
            BorderBrush="#33000000"
            Background="#11000000" />
    </Grid>
</Window>
