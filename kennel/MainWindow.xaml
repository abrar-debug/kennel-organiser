<Window x:Class="kennel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:kennel"
        mc:Ignorable="d"
        Title="Kennel Organiser"
        Height="320"
        Width="520"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <!-- Window heading -->
            <TextBlock
                DockPanel.Dock="Left"
                Text="Kennel Organiser"
                FontSize="22"
                FontWeight="SemiBold" />

            <Button
                x:Name="AddKennelButton"
                DockPanel.Dock="Right"
                Content="Add"
                Width="90"
                Height="32"
                Margin="12,0,0,0"
                Click="AddKennelButton_Click" />
        </DockPanel>

        <!-- Placeholder area for the organisation blocks -->
        <Border
            Grid.Row="1"
            CornerRadius="10"
            BorderThickness="1"
            BorderBrush="#33000000"
            Background="#11000000">
            <TextBlock
                Margin="14"
                Foreground="#99000000"
                TextWrapping="Wrap"
                Text="Click &quot;Add&quot; to create a Kennel window on your desktop. Drag app shortcuts (.lnk) into a kennel to assign them." />
        </Border>
    </Grid>
</Window>
