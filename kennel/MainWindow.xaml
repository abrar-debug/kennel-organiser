<Window x:Class="kennel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:kennel"
        mc:Ignorable="d"
        Title="Kennel Organiser"
        Height="400"
        Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Heading -->
        <TextBlock Grid.Row="0"
                   Text="Kennel Organiser"
                   FontSize="20"
                   FontWeight="SemiBold" />

        <!-- Kennel list -->
        <Border Grid.Row="2"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="#22000000"
                Background="#08000000">
            <Grid>
                <!-- Empty state -->
                <TextBlock x:Name="EmptyLabel"
                           Margin="16"
                           Foreground="#88000000"
                           FontSize="13"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Text="No kennels yet. Click Add to create one."
                           Visibility="Collapsed" />

                <!-- List -->
                <ListView x:Name="KennelListView"
                          Background="Transparent"
                          BorderThickness="0"
                          SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10"
                                    BorderBrush="#11000000"
                                    BorderThickness="0,0,0,1">
                                <DockPanel LastChildFill="True">
                                    <!-- Delete button -->
                                    <Button DockPanel.Dock="Right"
                                            Content="Delete"
                                            Width="64"
                                            Height="26"
                                            FontSize="12"
                                            Tag="{Binding Id}"
                                            Click="DeleteKennel_Click" />

                                    <!-- Shortcut count badge -->
                                    <TextBlock DockPanel.Dock="Right"
                                               Margin="0,0,10,0"
                                               Foreground="#66000000"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Text="{Binding ShortcutCountLabel}" />

                                    <!-- Kennel name -->
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Add button -->
        <Button Grid.Row="4"
                x:Name="AddKennelButton"
                Content="+ Add Kennel"
                Height="34"
                FontSize="13"
                HorizontalAlignment="Stretch"
                Click="AddKennelButton_Click" />
    </Grid>
</Window>
