<Window x:Class="kennel.KennelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Width="96"
        Height="64"
        AllowDrop="True"
        DragEnter="KennelWindow_DragEnter"
        DragLeave="KennelWindow_DragLeave"
        Drop="KennelWindow_Drop">
    <Border x:Name="RootBorder"
            CornerRadius="12"
            Background="#22000000"
            BorderBrush="#33000000"
            BorderThickness="1">

        <!-- Whole surface is draggable -->
        <Grid MouseLeftButtonDown="HeaderBorder_MouseLeftButtonDown"
              MouseMove="HeaderBorder_MouseMove"
              MouseLeftButtonUp="HeaderBorder_MouseLeftButtonUp">

            <!-- ── COLLAPSED VIEW: name centered ── -->
            <TextBlock x:Name="KennelNameText"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="10"
                       Visibility="Visible" />

            <!-- ── EXPANDED VIEW: name left | divider | icons right ── -->
            <DockPanel x:Name="ExpandedPanel"
                       Visibility="Collapsed"
                       LastChildFill="True">

                <!-- Name column -->
                <Border DockPanel.Dock="Left"
                        BorderBrush="#44FFFFFF"
                        BorderThickness="0,0,1,0"
                        MinWidth="80"
                        Padding="10,0">
                    <TextBlock x:Name="KennelNameExpandedText"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="90" />
                </Border>

                <!-- Icons column -->
                <StackPanel VerticalAlignment="Center"
                            Orientation="Vertical"
                            Margin="8,0">
                    <TextBlock x:Name="EmptyHintText"
                               Foreground="#77FFFFFF"
                               FontSize="11"
                               Text="Drop .lnk files here"
                               Visibility="Collapsed"
                               HorizontalAlignment="Center" />

                    <ListBox x:Name="ShortcutsList"
                             Background="Transparent"
                             BorderThickness="0"
                             MouseDoubleClick="ShortcutsList_MouseDoubleClick"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical"
                                            HorizontalAlignment="Center"
                                            Margin="6,0"
                                            ToolTip="{Binding DisplayName}">
                                    <Image Source="{Binding Icon}"
                                           Width="26"
                                           Height="26"
                                           Margin="0,0,0,3"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="White"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Width="62" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </DockPanel>

        </Grid>
    </Border>
</Window>
