<Window x:Class="kennel.KennelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        x:Name="KennelRoot"
        Width="96"
        Height="96"
        AllowDrop="True"
        DragEnter="KennelWindow_DragEnter"
        DragLeave="KennelWindow_DragLeave"
        Drop="KennelWindow_Drop">
    <Border x:Name="RootBorder"
            CornerRadius="12"
            Background="#22000000"
            BorderBrush="#33000000"
            BorderThickness="1">
        <Grid x:Name="KennelLayoutGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header: drag to move -->
            <Border x:Name="HeaderBorder"
                    Grid.Row="0"
                    Background="#11000000"
                    BorderBrush="#33000000"
                    BorderThickness="0,0,0,1"
                    Padding="8"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="HeaderBorder_MouseLeftButtonDown"
                    MouseMove="HeaderBorder_MouseMove"
                    MouseLeftButtonUp="HeaderBorder_MouseLeftButtonUp">
                <DockPanel LastChildFill="True">
                    <TextBlock x:Name="KennelNameText"
                               DockPanel.Dock="Left"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Text="Kennel"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />

                    <TextBlock x:Name="DropHintText"
                               DockPanel.Dock="Right"
                               Foreground="#66FFFFFF"
                               FontSize="11"
                               Text=".lnk drop" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="EmptyHintText"
                           Grid.Row="0"
                           Foreground="#66FFFFFF"
                           FontSize="12"
                           Text="Drag app shortcuts (.lnk) here"
                           Visibility="Collapsed"
                           Margin="0,0,0,8" />

                <ListBox x:Name="ShortcutsList"
                         Grid.Row="1"
                         Background="#00000000"
                         BorderThickness="0"
                         MouseDoubleClick="ShortcutsList_MouseDoubleClick"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemWidth="92" ItemHeight="58" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical"
                                        HorizontalAlignment="Center"
                                        Margin="0"
                                        ToolTip="{Binding DisplayName}">
                                <Image Source="{Binding Icon}"
                                       Width="26"
                                       Height="26"
                                       Margin="0,0,0,2"
                                       Stretch="Uniform" />
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="White"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Width="80" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</Window>

